# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Server-side only (Vercel env vars, never expose to browser)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Client-side (safe to expose — publishable key only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server-side only (Vercel env vars, never expose to browser)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — created in Stripe Dashboard (see src/lib/stripe-setup.md)
STRIPE_PRICE_ESSENTIAL=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# or
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@yourdomain.com

# ── AI / Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Push Notifications ────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:admin@yourdomain.com
